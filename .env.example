# =============================================================
# A. 초간단 데모 모드 (OAuth 없이 즉시 띄움)
# =============================================================
# 아래 한 줄만 활성화하면 Google 로그인 없이 동작합니다.
# 모든 사용자가 단일 'demo' 공용 계정을 공유합니다.
DEMO_MODE=false

# =============================================================
# B. 정식 운영 모드 (Google OAuth)
# =============================================================
# Postgres 비밀번호
POSTGRES_PASSWORD=change_me_please

# Google OAuth (https://console.cloud.google.com)
# Authorized redirect URI: http://<서버주소>:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# 가입 도메인 제한 (회사 Workspace 도메인). 비워두면 모든 Google 계정 허용.
ALLOWED_EMAIL_DOMAIN=

# 외부에서 프런트로 접속할 URL
NEXTAUTH_URL=http://localhost:3000

# openssl rand -base64 32 으로 만든 랜덤 문자열
NEXTAUTH_SECRET=change_me_to_a_long_random_string

# 백엔드 CORS 허용 origin (정식 모드에서만 의미 있음)
CORS_ORIGINS=http://localhost:3000

# 동시에 처리할 영상 분석 작업 수
MAX_CONCURRENT_JOBS=2

# =============================================================
# C. CLI 단독 사용 시 (.env에서 필요)
# =============================================================
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash
VISION_PROVIDER=gemini

# Gemini 호출 사이 대기 시간(초). 무료 한도(분당 15회) 회피용. 기본 5초.
GEMINI_REQUEST_INTERVAL=5
# 429(rate limit) 발생 시 자동 재시도 횟수. 기본 3회 (10s, 20s, 40s 백오프).
GEMINI_MAX_RETRIES=3

# =============================================================
# D. 컷 디텍터 선택 (선택 사항)
# =============================================================
# scenedetect (기본): 픽셀 차이 기반. 가벼움. 디졸브/페이드 약함.
# transnet:           TransNetV2(딥러닝). 디졸브/페이드/플래시 강함. TensorFlow 필요.
DETECTOR=scenedetect

# TransNetV2 사용 시:
#   1) git clone https://github.com/soCzech/TransNetV2.git 을
#      프로젝트 옆 폴더에 clone (E:\Claude\TransNetV2 처럼)
#   2) pip install tensorflow ffmpeg-python
#   3) DETECTOR=transnet 로 변경
# 기본 임계값 0.5. 0.3~0.7 사이로 튜닝.
TRANSNET_THRESHOLD=0.5
# TransNetV2 레포 경로. 비우면 프로젝트 부모 폴더의 TransNetV2 자동 사용.
# TRANSNET_PATH=E:\Claude\TransNetV2
