# =============================================================
# CLI 단독 사용 시 (shotbreakdown 패키지)
# =============================================================
# Gemini API 키 (https://aistudio.google.com 에서 발급)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash
VISION_PROVIDER=gemini

# =============================================================
# 웹 앱 (docker compose) 사용 시
# =============================================================

# Postgres 비밀번호 (사내 LAN 운영이면 임의 문자열)
POSTGRES_PASSWORD=change_me_please

# Google OAuth (Google Cloud Console에서 OAuth 클라이언트 생성)
# - Authorized redirect URI: http://<서버 IP>:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# 가입 도메인 제한 (회사 Workspace 도메인). 비워두면 모든 Google 계정 허용.
ALLOWED_EMAIL_DOMAIN=company.com

# NextAuth - 외부에서 접속할 URL (사내 IP + 포트)
# 예) http://192.168.0.50:3000
NEXTAUTH_URL=http://localhost:3000

# 임의의 긴 랜덤 문자열 (예: openssl rand -base64 32)
NEXTAUTH_SECRET=change_me_to_a_long_random_string

# 브라우저가 백엔드를 부를 주소 (NEXTAUTH_URL과 같은 IP, 포트만 8000)
PUBLIC_API_URL=http://localhost:8000

# 프런트가 백엔드 호출할 때 허용할 origin
CORS_ORIGINS=http://localhost:3000

# 동시에 처리할 영상 분석 작업 수 (사내 PC 사양에 맞춰 조정)
MAX_CONCURRENT_JOBS=2
